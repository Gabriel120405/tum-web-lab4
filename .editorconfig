# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8

# JavaScript, JSON, YAML files
[*.{js,json,yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false

# CSS files
[*.css]
indent_style = space
indent_size = 2

# HTML files
[*.{html,njk}]
indent_style = space
indent_size = 2
